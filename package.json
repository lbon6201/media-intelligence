{
  "name": "media-intelligence",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "cd client && npx vite",
    "build": "cd client && npm install && npx vite build",
    "start": "node server/index.js",
    "migrate": "node server/migrate-postgres.js"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.7.0",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "jsdom": "^29.0.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.20.0",
    "uuid": "^11.0.3",
    "xlsx": "^0.18.5"
  }
}
