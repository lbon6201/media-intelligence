{
  "manifest_version": 3,
  "name": "Media Intelligence Clipper",
  "version": "1.0",
  "description": "Clip articles to Media Intelligence Platform",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}
