{
  "manifest_version": 3,
  "name": "Media Intelligence Clipper",
  "version": "1.1",
  "description": "Clip articles to Media Intelligence Platform",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:*/*", "https://*.up.railway.app/*", "https://*.railway.app/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}
